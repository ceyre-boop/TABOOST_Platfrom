rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // TEMPORARY RULES FOR BULK IMPORT
    // Switch to production.rules after import is complete!
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Users collection - allow read/write for setup
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }
    
    // Creator roster - ALLOW ALL WRITES FOR IMPORT
    match /creatorRoster/{username} {
      allow read: if true;
      allow write: if isAuthenticated();  // Temporarily allow any authenticated user
    }
    
    // Creator data
    match /creators/{cid} {
      allow read, write: if isAuthenticated();
    }
    
    // Admin collection
    match /admins/{adminId} {
      allow read, write: if isAuthenticated();
    }
    
    // Signup audit log
    match /signups/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    // Analytics
    match /analytics/{docId} {
      allow read, write: if isAuthenticated();
    }
  }
}

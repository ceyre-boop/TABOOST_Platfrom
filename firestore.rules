rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if user is manager
    function isManager() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own data
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Admin can read/write all user data
      allow read, write: if isAdmin();
      
      // Managers can read creator data
      allow read: if isManager() && 
        get(/databases/$(database)/documents/users/$(userId)).data.role == 'creator';
    }
    
    // Roster collection - pre-approved TikTok usernames
    match /roster/{username} {
      // Authenticated users can read roster
      allow read: if request.auth != null;
      
      // Only admin can modify roster
      allow write: if isAdmin();
    }
    
    // Signups log - for audit trail
    match /signups/{docId} {
      // Admin can read all signups
      allow read: if isAdmin();
      
      // Authenticated users can create signup records
      allow create: if request.auth != null;
    }
    
    // Creator data (metrics, goals, etc.)
    match /creatorData/{username} {
      // Creator can read their own data
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username == username;
      
      // Admin can read/write all
      allow read, write: if isAdmin();
      
      // Manager can read their assigned creators
      allow read: if isManager();
    }
    
    // Manager assignments
    match /managerAssignments/{managerId} {
      // Manager can read their own assignments
      allow read: if request.auth != null && request.auth.uid == managerId;
      
      // Admin can read/write
      allow read, write: if isAdmin();
    }
    
    // Audit logs
    match /auditLogs/{logId} {
      // Admin can read
      allow read: if isAdmin();
      
      // Authenticated users can create logs
      allow create: if request.auth != null;
    }
  }
}
